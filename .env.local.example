# Configuración para desarrollo local
# Copia este archivo a .env.local para usarlo

# Deshabilitar logs de telemetría en desarrollo
NEXT_PUBLIC_ENABLE_TELEMETRY=false

# Modo debug para preload (cambiar a true para ver logs detallados)
NEXT_PUBLIC_DEBUG_PRELOAD=false

# Modo debug para video cache (cambiar a true para ver logs detallados)
NEXT_PUBLIC_DEBUG_VIDEO_CACHE=false
